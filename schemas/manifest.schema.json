{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SETCO Manifest",
  "description": "Meta-compilation manifest",
  "type": "object",
  "required": ["manifest_id", "repo", "corpus_root", "targets"],
  "properties": {
    "manifest_id": {
      "type": "string"
    },
    "repo": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "corpus_root": {
      "type": "string"
    },
    "source_format": {
      "type": "string"
    },
    "targets": {
      "type": "array",
      "items": { "type": "string" }
    },
    "mode": {
      "type": "string",
      "enum": ["manifest-driven-generation", "semantic-parsing", "claim-promotion"]
    },
    "pass": {
      "type": "string"
    }
  }
}
