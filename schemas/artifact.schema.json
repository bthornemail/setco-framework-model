{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SETCO Artifact",
  "description": "A classified artifact in the SETCO framework",
  "type": "object",
  "required": ["id", "artifact_type", "source", "classification"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique artifact identifier"
    },
    "artifact_type": {
      "type": "string",
      "enum": ["proof", "implementation", "defined_model", "interpretation", "projection", "adapter", "application_surface"]
    },
    "source": {
      "type": "object",
      "properties": {
        "corpus_path": { "type": "string" },
        "file": { "type": "string" }
      }
    },
    "classification": {
      "$ref": "classification.schema.json"
    },
    "authority": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["proved", "implemented", "defined_model", "interpretation"]
        },
        "allowed_use": { "type": "string" },
        "forbidden_use": { "type": "string" }
      }
    }
  }
}
