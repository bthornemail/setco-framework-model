  "authority_gates": {
    "auth-runtime-kernel": "All G1.x pass",
    "auth-compiler": "All G2.x pass",
    "auth-omniprocessor": "All G3.x pass",
    "auth-envelope-construction": "All G4.x pass",
    "auth-legacy-execution": "All G5.x pass"
  }
